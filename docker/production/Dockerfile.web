# syntax=docker/dockerfile:1
FROM python:3.12-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    UV_LINK_MODE=copy uv sync --extra db --extra storage --extra web --no-dev --no-editable

COPY stopsign /app/stopsign
COPY static /app/static
COPY config/config.example.yaml /app/config.example.yaml

# Runtime stage — clean image without build artifacts
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    libpq5 \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL "https://github.com/Infisical/cli/releases/latest/download/cli_$(uname -s | tr '[:upper:]' '[:lower:]')_amd64.tar.gz" | tar -xz -C /usr/local/bin infisical

WORKDIR /app

COPY --from=builder /app /app
RUN printf '#!/bin/sh\nset -e\nif [ -n "$INFISICAL_CLIENT_ID" ] && [ -n "$INFISICAL_CLIENT_SECRET" ]; then\n  INFISICAL_TOKEN=$(curl -sf -X POST "https://secrets.drose.io/api/v1/auth/universal-auth/login" -H "Content-Type: application/json" -d "{\\"clientId\\":\\"${INFISICAL_CLIENT_ID}\\",\\"clientSecret\\":\\"${INFISICAL_CLIENT_SECRET}\\"}" | python3 -c "import json,sys; print(json.load(sys.stdin)['"'"'accessToken'"'"'])")\n  export INFISICAL_TOKEN\n  exec infisical run --projectId "9c373776-768f-454b-a7b3-d1cc40deb475" --env "${INFISICAL_ENV:-prod}" --domain "https://secrets.drose.io" -- "$@"\nelse\n  exec "$@"\nfi\n' > /entrypoint.sh && chmod +x /entrypoint.sh

ENV PATH="/app/.venv/bin:$PATH"

ENTRYPOINT ["/entrypoint.sh"]
CMD ["python", "-m", "stopsign.web_server"]
