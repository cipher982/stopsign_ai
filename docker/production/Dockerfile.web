# syntax=docker/dockerfile:1
FROM python:3.12-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    UV_LINK_MODE=copy uv sync --extra db --extra storage --extra web --no-dev --no-editable

COPY stopsign /app/stopsign
COPY static /app/static
COPY config/config.example.yaml /app/config.example.yaml

# Runtime stage — clean image without build artifacts
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    libpq5 \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL "https://github.com/Infisical/cli/releases/latest/download/cli_$(uname -s | tr '[:upper:]' '[:lower:]')_amd64.tar.gz" | tar -xz -C /usr/local/bin infisical

WORKDIR /app

COPY --from=builder /app /app
COPY docker/production/entrypoint.sh /entrypoint.sh

ENV PATH="/app/.venv/bin:$PATH"

ENTRYPOINT ["/entrypoint.sh"]
CMD ["python", "-m", "stopsign.web_server"]
